PORT=8000
MONGO_URI=
JWT_SECRET=ChangeThisJwtSecretForDevelopment123!
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10

SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=ChangeMe123!
SUPER_ADMIN_SEED_DB=false

# Optional: allow self-service admin signup only when this code is set.
ADMIN_ACCESS_CODE=

# Comma-separated CORS origins.
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Optional production hardening knobs.
ENABLE_API_DOCS=false
JSON_BODY_LIMIT=100kb
URL_ENCODED_BODY_LIMIT=100kb
GLOBAL_RATE_LIMIT_PER_MINUTE=300
AUTH_RATE_LIMIT_PER_15_MINUTES=25
LOG_RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=info
CHAT_SOCKET_EVENT_LIMIT_PER_MINUTE=120
CHAT_SOCKET_MAX_PAYLOAD_BYTES=10000
# Use "system" to use OS DNS. Default keeps MongoDB Atlas SRV lookups stable on some networks.
DNS_SERVERS=8.8.8.8,8.8.4.4

# Development only: print OTP in backend terminal while email/SMS is not configured.
DEV_LOG_OTP=true

# Development only: set true if you want every API request printed in the terminal.
DEV_LOG_HTTP_REQUESTS=false
