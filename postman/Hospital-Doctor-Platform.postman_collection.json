      }
    },
    {
      "name": "Hospital - Approve Doctor",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{hospitalToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"doctorId\": \"{{doctorId}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/hospitals/{{hospitalId}}/approve-doctor",
          "host": ["{{baseUrl}}"],
          "path": ["api", "hospitals", "{{hospitalId}}", "approve-doctor"]
        }
      }
    },
    {
      "name": "Admin - Set Default Subscription",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"amount\": 500\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/subscription/default",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "subscription", "default"]
        }
      }
    },
    {
      "name": "Admin - Override Hospital Subscription",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"hospitalId\": \"{{hospitalId}}\",\n  \"amount\": 1200\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/admin/subscription/hospital",
          "host": ["{{baseUrl}}"],
          "path": ["api", "admin", "subscription", "hospital"]
        }
      }
    },
    {
      "name": "Hospital - Get Subscription",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{hospitalToken}}"
