{
  "openapi": "3.0.3",
  "info": {
    "title": "Hospital Token Booking API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000/api",
      "description": "Local development server"
    }
  ],
  "tags": [
    {
      "name": "Auth Module",
      "description": "Authentication and OTP verification APIs."
    },
    {
      "name": "Department Selection",
      "description": "Department dropdown and department management APIs."
    },
    {
      "name": "Hospital Module",
      "description": "Hospital user APIs for fetching and updating the selected department."
    },
    {
      "name": "Admin Module",
      "description": "Admin approval, onboarding, and user management APIs."
    },
    {
      "name": "Super Admin Module",
      "description": "Super admin APIs for managing admin users."
    },
    {
      "name": "System",
      "description": "Utility and health-check APIs."
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": [
          "name",
          "age",
          "gender",
          "role",
          "specialization",
          "email",
          "password",
          "confirmPassword"
        ],
        "properties": {
          "name": { "type": "string", "example": "Dr Asha" },
          "age": { "type": "number", "example": 32 },
          "gender": { "type": "string", "example": "female" },
          "role": { "type": "string", "example": "doctor" },
          "specialization": { "type": "string", "example": "Cardiology" },
          "departmentId": {
            "type": "string",
            "example": "67e3a1c2e2a5f83a9b8c1234",
            "description": "Required when role is doctor or common_user"
          },
          "email": { "type": "string", "example": "asha@example.com" },
          "password": { "type": "string", "example": "Pass@123" },
          "confirmPassword": { "type": "string", "example": "Pass@123" }
        }
      },
      "VerifyOtpRequest": {
        "type": "object",
        "required": ["email", "otp"],
        "properties": {
          "email": { "type": "string", "example": "asha@example.com" },
          "otp": { "type": "string", "example": "123456" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "example": "asha@example.com" },
          "password": { "type": "string", "example": "Pass@123" }
        }
      },
      "CreateAdminRequest": {
        "type": "object",
        "required": [
          "name",
          "age",
          "gender",
          "specialization",
          "email",
          "password",
          "confirmPassword"
        ],
        "properties": {
          "name": { "type": "string", "example": "Admin One" },
          "age": { "type": "number", "example": 40 },
          "gender": { "type": "string", "example": "male" },
          "specialization": { "type": "string", "example": "Operations" },
          "email": { "type": "string", "example": "admin1@example.com" },
          "password": { "type": "string", "example": "Admin@123" },
          "confirmPassword": { "type": "string", "example": "Admin@123" }
        }
      },
      "CreateDepartmentRequest": {
        "type": "object",
        "required": ["departmentName"],
        "properties": {
          "departmentName": {
            "type": "string",
            "example": "Cardiology",
            "description": "Unique department name. Leading and trailing spaces are trimmed."
          }
        }
      },
      "UpdateDepartmentRequest": {
        "type": "object",
        "required": ["departmentName"],
        "properties": {
          "departmentName": {
            "type": "string",
            "example": "Advanced Cardiology",
            "description": "Updated unique department name."
          }
        }
      },
      "DepartmentItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "67e3a1c2e2a5f83a9b8c1234" },
          "name": { "type": "string", "example": "Cardiology" }
        }
      },
      "UpdateHospitalDepartmentRequest": {
        "type": "object",
        "required": ["departmentId"],
        "properties": {
          "departmentId": {
            "type": "string",
            "example": "67e3a1c2e2a5f83a9b8c1234",
            "description": "MongoDB ObjectId of the selected department."
          }
        }
      },
      "HospitalItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "67e3a1c2e2a5f83a9b8c9999" },
          "name": { "type": "string", "example": "Main Hospital User" },
          "departmentId": { "type": "string", "example": "67e3a1c2e2a5f83a9b8c1234", "nullable": true },
          "departmentName": { "type": "string", "example": "Cardiology" }
        }
      },
      "SuccessResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string", "example": "OK" },
          "data": { "type": "object", "nullable": true }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string", "example": "Validation error" },
          "errors": { "type": "object", "nullable": true }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Unauthorized",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "Invalid or expired token",
              "errors": null
            }
          }
        }
      },
      "Forbidden": {
        "description": "Forbidden",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "Forbidden: insufficient permissions",
              "errors": null
            }
          }
        }
      },
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" },
            "example": {
              "success": false,
              "message": "Missing required fields",
              "errors": null
            }
          }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth Module"],
        "summary": "Register user (doctor / common_user / admin)",
        "description": "Creates a user with loginStatus=PENDING and onboardingStatus=NOT_ONBOARDED. Doctors and common users must provide a valid departmentId from GET /departments. OTP is printed in the server terminal.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" },
              "example": {
                "name": "Dr Asha",
                "age": 32,
                "gender": "female",
                "role": "doctor",
                "specialization": "Cardiology",
                "departmentId": "67e3a1c2e2a5f83a9b8c1234",
                "email": "asha@example.com",
                "password": "Pass@123",
                "confirmPassword": "Pass@123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User registered",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "User registered. Please verify OTP.",
                  "data": { "userId": "65f1a1c2e2a5f83a9b8c1234" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/auth/verify-register-otp": {
      "post": {
        "tags": ["Auth Module"],
        "summary": "Verify registration OTP",
        "description": "Marks the user's email as verified.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VerifyOtpRequest" },
              "example": { "email": "asha@example.com", "otp": "123456" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP verified",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Email verified successfully",
                  "data": null
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth Module"],
        "summary": "Login step 1 (generate OTP)",
        "description": "Validates credentials, approval and onboarding status, then prints OTP in the terminal.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" },
              "example": { "email": "asha@example.com", "password": "Pass@123" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OTP sent",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "OTP sent. Please verify to complete login.",
                  "data": null
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/auth/verify-login-otp": {
      "post": {
        "tags": ["Auth Module"],
        "summary": "Login step 2 (verify OTP)",
        "description": "Verifies OTP and returns JWT token and role.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/VerifyOtpRequest" },
              "example": { "email": "asha@example.com", "otp": "123456" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Login successful",
                  "data": {
                    "token": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...",
                    "role": "doctor"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/departments": {
      "get": {
        "tags": ["Department Selection"],
        "summary": "Get all departments",
        "description": "Returns department values for dropdowns and other reusable modules.",
        "responses": {
          "200": {
            "description": "Departments fetched successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Departments fetched successfully",
                  "data": [
                    { "id": "67e3a1c2e2a5f83a9b8c1234", "name": "Cardiology" },
                    { "id": "67e3a1c2e2a5f83a9b8c1235", "name": "Neurology" }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Department Selection"],
        "summary": "Create department (super admin only)",
        "description": "Creates a department with a generated departmentId such as DEP001.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateDepartmentRequest" },
              "example": {
                "departmentName": "Cardiology"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Department created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Department created",
                  "data": {
                    "id": "67e3a1c2e2a5f83a9b8c1234",
                    "name": "Cardiology"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/departments/{id}": {
      "put": {
        "tags": ["Department Selection"],
        "summary": "Update department (super admin only)",
        "description": "Updates the department name. Existing users mapped to the department are updated with the latest departmentName.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Department ObjectId or departmentId such as DEP001",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateDepartmentRequest" },
              "example": {
                "departmentName": "Advanced Cardiology"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Department updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Department updated",
                  "data": {
                    "id": "67e3a1c2e2a5f83a9b8c1234",
                    "name": "Advanced Cardiology"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "delete": {
        "tags": ["Department Selection"],
        "summary": "Delete department (super admin only)",
        "description": "Deletes a department only when no users are assigned to it.",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Department ObjectId or departmentId such as DEP001",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Department deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Department deleted",
                  "data": {
                    "id": "67e3a1c2e2a5f83a9b8c1234",
                    "name": "Cardiology"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/hospital/{id}": {
      "get": {
        "tags": ["Hospital Module"],
        "summary": "Get hospital user details",
        "description": "Returns hospital user details including the currently selected department.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Hospital user MongoDB ObjectId",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Hospital user fetched successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Hospital user fetched successfully",
                  "data": {
                    "id": "67e3a1c2e2a5f83a9b8c9999",
                    "name": "Main Hospital User",
                    "departmentId": "67e3a1c2e2a5f83a9b8c1234",
                    "departmentName": "Cardiology"
                  }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/hospital/{id}/department": {
      "put": {
        "tags": ["Hospital Module"],
        "summary": "Assign or update hospital user department",
        "description": "Assigns a department if not set, or updates the selected department if it already exists.",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Hospital user MongoDB ObjectId",
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateHospitalDepartmentRequest" },
              "example": {
                "departmentId": "67e3a1c2e2a5f83a9b8c1234"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Hospital department updated successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Hospital department updated successfully",
                  "data": {
                    "id": "67e3a1c2e2a5f83a9b8c9999",
                    "name": "Main Hospital User",
                    "departmentId": "67e3a1c2e2a5f83a9b8c1234",
                    "departmentName": "Cardiology"
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/admin/users/{id}/approve": {
      "patch": {
        "tags": ["Admin Module"],
        "summary": "Approve user login",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "User approved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "User approved",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c1234" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/admin/users/{id}/reject": {
      "patch": {
        "tags": ["Admin Module"],
        "summary": "Reject user login",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "User rejected",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "User rejected",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c1234" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/admin/users/{id}/onboard": {
      "patch": {
        "tags": ["Admin Module"],
        "summary": "Complete onboarding",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "User onboarded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "User onboarded",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c1234" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/admin/users/{id}": {
      "delete": {
        "tags": ["Admin Module"],
        "summary": "Delete user",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "User deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "User deleted",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c1234" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/superadmin/admins": {
      "post": {
        "tags": ["Super Admin Module"],
        "summary": "Create admin (super admin only)",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateAdminRequest" },
              "example": {
                "name": "Admin One",
                "age": 40,
                "gender": "male",
                "specialization": "Operations",
                "email": "admin1@example.com",
                "password": "Admin@123",
                "confirmPassword": "Admin@123"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Admin created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Admin created",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c5678" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/superadmin/admins/{id}": {
      "delete": {
        "tags": ["Super Admin Module"],
        "summary": "Delete admin (super admin only)",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Admin deleted",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "Admin deleted",
                  "data": { "id": "65f1a1c2e2a5f83a9b8c5678" }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
    },
    "/health": {
      "get": {
        "tags": ["System"],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SuccessResponse" },
                "example": {
                  "success": true,
                  "message": "OK"
                }
              }
            }
          }
        }
      }
    }
  }
}
